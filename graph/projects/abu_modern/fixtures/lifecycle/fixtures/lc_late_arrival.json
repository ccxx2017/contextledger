  "rfc_reference": "contracts/05_phase1_lifecycle_schema.md#bitemporal-boundaries",
  "input": {
    "event_stream": [
      {
        "event_id": "evt_030",
        "observed_at": "2026-07-01T10:00:00Z",
        "effective_at": "2026-07-01T10:00:00Z",
        "source": "inventory",
        "payload": {
          "entity_ref": "SKU-2026-A",
          "lifecycle_ref": "lc_sku_a",
          "lifecycle_seq": 1,
          "adjudication_key": "inventory:SKU-2026-A",
          "node_type": "Fact",
          "content": "Price band A published.",
          "state": "implemented",
          "alias_hints": null
        }
      },
      {
        "event_id": "evt_031",
        "observed_at": "2026-07-03T10:00:00Z",
        "effective_at": "2026-07-02T10:00:00Z",
        "source": "inventory",
        "payload": {
          "entity_ref": "SKU-2026-A",
          "lifecycle_ref": "lc_sku_a",
          "lifecycle_seq": 2,
          "adjudication_key": "inventory:SKU-2026-A",
          "node_type": "Fact",
