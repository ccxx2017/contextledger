        "superseded_nodes": ["n_price_band_a"],
        "pending_nodes": [],
        "relations": [
          { "relation_type": "supersedes", "source": "n_price_band_b", "target": "n_price_band_a" }
        ],
        "quarantine": [],
        "assembler_must_include": ["n_price_band_b"]
      }
    ]
  }
