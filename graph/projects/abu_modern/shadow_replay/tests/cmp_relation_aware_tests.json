[
  {
    "test_id": "cmp_supersedes_matches_supersedes",
    "description": "Gold expects SUPERCEDES, shadow has SUPERCEDES and active-state consistent. Should be expected_improvement.",
    "gold": {
      "expected_active_set": [
        "c2"
      ],
      "expected_invalidations": [
        {
          "dropped_claims": [
            "c1"
          ],
          "replacement_claims": [
            "c2"
          ]
        }
      ],
      "must_include": [
        "c2"
      ]
    },
    "shadow": {
      "nodes": {
        "n1": {
          "claim_id": "c1",
          "status": "superseded"
        },
        "n2": {
          "claim_id": "c2",
          "status": "active"
        }
      },
      "edges": [
        {
          "source": "n2",
          "target": "n1",
          "relation": "supersedes"
        }
      ],
      "bundle": {
        "must_include": [
          "n2"
        ]
      }
    },
    "expected_classifications": {
      "active_set": 0,
      "invalidation": "expected_improvement",
      "must_include": 0
    }
  },
